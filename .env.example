# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
# A random secret key — change this before deploying to production
SECRET_KEY=ticketinit-change-this-in-production
# The public base URL of your app (used in QR code verify links)
APP_BASE_URL=https://your-domain.co.ke

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ticketinit:ticketinit_pass@localhost:5432/ticketinit_db

# ── M-Pesa Daraja API ──────────────────────────────────────────────────────────
# Get these from https://developer.safaricom.co.ke after creating an app
#
# Environment: "sandbox" for testing, "production" for live payments
MPESA_ENV=sandbox

# Your app's Consumer Key and Secret (from Safaricom Developer Portal)
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# Business/Paybill shortcode
#   Sandbox default: 174379  (Safaricom's test shortcode)
#   Production: your actual Paybill or Till number
MPESA_SHORTCODE=174379

# Lipa Na M-Pesa Online passkey
#   Sandbox: leave blank — the code uses Safaricom's official test passkey automatically
#   Production: paste the passkey from your Safaricom portal
MPESA_PASSKEY=

# The callback URL Safaricom will POST STK results to.
# This MUST be a publicly accessible HTTPS URL.
# For local development, use ngrok:
#   ngrok http 8000  →  https://abc123.ngrok-free.app
#   Then set: MPESA_CALLBACK_URL=https://abc123.ngrok-free.app/payments/mpesa/callback
MPESA_CALLBACK_URL=https://your-domain.co.ke/payments/mpesa/callback
